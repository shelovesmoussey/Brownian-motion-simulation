import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# 1. Setup
t = np.linspace(0, 7, 500)
level_a = 0.9
plt.figure(figsize=(10, 5))

# 2. Generate and Plot
for i in range(3):
    # Creating a random walk (approximation of Brownian Motion)
    # Scale by 0.1 to keep the variance realistic for the 0-7 time range
    steps = np.random.normal(0, 0.1, 500)
    path = np.cumsum(steps)
    
    plt.plot(t, path, label=f'Path {i+1}')

# 3. Add the Hitting Level and Styling
plt.axhline(y=level_a, color='black', linestyle='-', linewidth=2, label='Level a')
plt.title("Brownian Motion Hitting Times")
plt.xlabel("Time (t)")
plt.ylabel("B_t")
plt.ylim(-4, 2)
plt.grid(True, alpha=0.3)
plt.legend()
plt.show()
